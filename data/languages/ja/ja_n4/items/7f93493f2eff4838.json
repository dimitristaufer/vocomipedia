  "sentences": [
    {
      "target": "夏休みにオリジナルのロボットを作るぞ！",
      "reading": "なつやすみにおりじなるのろぼっとをつくるぞ！",
      "translations": {
        "en": "I'm going to make an original robot this summer vacation!",
        "es": "¡Voy a hacer un robot original estas vacaciones de verano!",
        "fr": "Je vais créer un robot original ces vacances d’été !",
        "de": "Ich werde in diesen Sommerferien einen originalen Roboter bauen!",
        "it": "Quest'estate realizzerò un robot originale!",
        "ko": "이번 여름 방학에 오리지널 로봇을 만들 거야!",
        "zh-Hans": "我打算在暑假做一个原创机器人！",
        "yue": "今個暑假我要整一個原創機械人！",
        "ru": "Я собираюсь сделать оригинального робота этим летом на каникулах!",
        "pt": "Vou fazer um robô original nessas férias de verão!",
        "he": "אני הולך להכין רובוט מקורי בחופשת הקיץ הקרובה!",
        "tr": "Bu yaz tatilinde orijinal bir robot yapacağım!",
        "vi": "Tôi sẽ làm một robot nguyên bản trong kỳ nghỉ hè này!",
        "ar": "سأصنع روبوتا أصليا في عطلة الصيف هذه!",
        "nl": "Ik ga deze zomervakantie een originele robot maken!",
        "uk": "Цього літнього канікул я зроблю оригінального робота!",
        "hu": "Ezen a nyári szüneten egy eredeti robotot fogok készíteni!",
        "hi": "मैं इस गर्मी की छुट्टी में एक मूल रोबोट बनाने जा रहा हूँ!",
        "pl": "Na wakacje letnie zrobię oryginalnego robota!",
        "el": "Θα φτιάξω ένα πρωτότυπο ρομπότ αυτές τις καλοκαιρινές διακοπές!",
        "nb": "Jeg skal lage en original robot denne sommerferien!",
        "id": "Saya akan membuat robot orisinal liburan musim panas ini!",
        "sv": "Jag ska göra en originell robot i sommarlovet!",
        "ro": "O să fac un robot original în vacanța de vară!",
        "cs": "Letos o prázdninách si vyrobím originálního robota!",
        "da": "Jeg vil lave en original robot i sommerferien!",
        "fi": "Aion tehdä alkuperäisen robotin tänä kesälomana!"
      },
